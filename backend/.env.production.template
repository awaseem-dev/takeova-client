# ═══════════════════════════════════════════════════════════════════
# MINE v49.1 — Production Environment Variables Template
# Copy this file to `.env` and fill in real values before deploying.
# NEVER commit the actual `.env` file to git.
# ═══════════════════════════════════════════════════════════════════

# ─── CORE ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://yourdomain.com

# ─── DATABASE ───────────────────────────────────────────────────────
# Option A: SQLite (recommended for v1 launch, use Litestream for backups)
DB_PATH=/app/data
# Option B: Postgres (recommended at 500+ paid users — see POSTGRES_MIGRATION.md)
# DATABASE_URL=postgres://user:pass@host:5432/mine

# ─── SECURITY ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=<GENERATE_32_CHAR_RANDOM_STRING>
JWT_SECRET=<GENERATE_DIFFERENT_32_CHAR_RANDOM_STRING>

# ─── ANTHROPIC ──────────────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-opus-4-7
# Optional fallback if primary model is overloaded:
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6

# ─── STRIPE ─────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# From Dashboard > Developers > Webhooks > [your endpoint] > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# From Dashboard > Connect > Settings
STRIPE_CONNECT_CLIENT_ID=ca_...
# Path to file generated by seed-stripe-products.js
STRIPE_PRICE_IDS_PATH=./config/stripe-prices.live.json

# ─── EMAIL (SendGrid) ───────────────────────────────────────────────
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.___
SENDGRID_FROM_EMAIL=hello@yourdomain.com
SENDGRID_FROM_NAME=MINE
# Optional: SMTP fallback if SendGrid is down
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASS=...

# ─── FILE STORAGE (S3-compatible) ───────────────────────────────────
AWS_S3_BUCKET=mine-uploads-prod
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
# Optional CloudFront CDN URL for faster delivery (leave blank to serve direct from S3):
# AWS_CLOUDFRONT_URL=https://cdn.yourdomain.com

# ─── SMS / VOICE (Twilio) ───────────────────────────────────────────
# Only needed for AI Receptionist + MINE Control WhatsApp features
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── AI VIDEO / IMAGE GENERATION ────────────────────────────────────
# Only needed if users create AI video ads
HEYGEN_API_KEY=hg_...
RUNWAY_API_KEY=...
NANOBANANA_API_KEY=...

# ─── OAUTH PROVIDERS ────────────────────────────────────────────────
# Sign in with Google + Google Calendar/GMB integration
GOOGLE_CLIENT_ID=___.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Sign in with Apple
APPLE_CLIENT_ID=com.yourdomain.web
APPLE_TEAM_ID=___
APPLE_KEY_ID=___
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Meta (Facebook + Instagram posting)
META_APP_ID=___
META_APP_SECRET=___

# LinkedIn posting
LINKEDIN_CLIENT_ID=___
LINKEDIN_CLIENT_SECRET=___

# TikTok posting
TIKTOK_CLIENT_KEY=___
TIKTOK_CLIENT_SECRET=___

# ─── ACCOUNTING OAUTH ───────────────────────────────────────────────
XERO_CLIENT_ID=___
XERO_CLIENT_SECRET=___
QB_CLIENT_ID=___
QB_CLIENT_SECRET=___

# ─── MONITORING ─────────────────────────────────────────────────────
# https://sentry.io — for error tracking
SENTRY_DSN=https://__@__.ingest.sentry.io/__

# ─── FEATURE FLAGS ──────────────────────────────────────────────────
# Enable/disable features without redeploying
ENABLE_AI_EMPLOYEES=true
ENABLE_AGENCY_MODE=true
ENABLE_MARKETPLACE=true
ENABLE_METERED_OVERAGES=true
# Lower to throttle expensive operations during incidents:
MAX_CONCURRENT_AI_REQUESTS=10
MAX_SITE_BUILDS_PER_HOUR=100

# ─── RATE LIMITS (per user) ─────────────────────────────────────────
RATE_LIMIT_AI_PER_MINUTE=10
RATE_LIMIT_PUBLIC_PER_MINUTE=60


# ═══════════════════════════════════════════════════════════════════
# ADDITIONAL VARIABLES DISCOVERED IN CODE AUDIT (session 30)
# These were referenced in routes/ but missing from the original
# template. Production deploys using the old template would have
# silently non-functional features. Add real values before deploying.
# ═══════════════════════════════════════════════════════════════════

# ── Auth & security ────────────────────────────────────────────────
JWT_REFRESH_SECRET=                    # refresh-token signing key (generate: openssl rand -hex 48)
OAUTH_STATE_SECRET=                    # HMAC secret for Xero/QuickBooks/Meta OAuth state
INTERNAL_API_KEY=                      # internal cron + service-to-service header auth
CRON_SECRET=                           # x-cron-key header for scheduled jobs
ADMIN_API_KEY=                         # admin-only ops / moderation API header
ADMIN_EMAIL=                           # address that receives critical alerts

# ── URLs / hosts ───────────────────────────────────────────────────
BACKEND_URL=https://api.mine.app       # full URL backend serves from (used in email links)
API_BASE_URL=                          # alt spelling some routes use
API_HOST=                              # alt spelling some routes use
APP_URL=                               # frontend URL (used in review-request + password-reset links)
MAIN_HOST=mine.app                     # default hostname for generated subdomains
MINE_DOMAIN=mine.app                   # matches MAIN_HOST in most deploys

# ── Email / SendGrid ───────────────────────────────────────────────
EMAIL_FROM=hello@mine.app              # default From: address
FROM_EMAIL=                            # alt spelling used in ai-employees.js (keep in sync with EMAIL_FROM)
EMAIL_FROM_DOMAIN=mine.app             # sending domain for cold-email agent
SENDGRID_WEBHOOK_PUBLIC_KEY=           # ECDSA public key for SendGrid Event Webhook verification
SENDGRID_WEBHOOK_KEY=                  # alt name in some routes
# SMTP fallback (only if not using SendGrid REST):
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ── Twilio / SMS ───────────────────────────────────────────────────
TWILIO_FROM=                           # fallback sender number (TWILIO_PHONE_NUMBER preferred)
SMS_SENDER_NAME=                       # alpha-sender name for regions that support it

# ── WhatsApp (Meta Cloud API) ──────────────────────────────────────
WHATSAPP_APP_SECRET=                   # required for webhook signature verification
WHATSAPP_API_KEY=                      # alt: WHATSAPP_ACCESS_TOKEN
WHATSAPP_ACCESS_TOKEN=                 # bearer token for send API
WHATSAPP_PHONE_NUMBER_ID=              # WABA phone-number ID
WHATSAPP_BUSINESS_NUMBER=              # display number for outgoing messages
WHATSAPP_BUSINESS_TOKEN=               # alt spelling in mine-control
WHATSAPP_VERIFY_TOKEN=                 # webhook verification token you set in Meta dashboard

# ── Social OAuth ───────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_CLIENT_ID=                     # for X/Twitter OAuth 2.0 PKCE flow
TWITTER_CLIENT_SECRET=

# ── QuickBooks / Xero (accounting) ─────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ACCESS_TOKEN=               # if using a single app-level token (most deploys use OAuth)
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ENV=production              # or "sandbox"
QBO_ACCESS_TOKEN=                      # alt spelling used in ai-employees.js
QBO_REALM_ID=                          # alt spelling used in ai-employees.js
XERO_ACCESS_TOKEN=                     # if using single app-level token
XERO_TENANT_ID=

# ── Stripe ─────────────────────────────────────────────────────────
STRIPE_CONNECT_WEBHOOK_SECRET=         # separate from main STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_STARTER=                  # Stripe Price ID for Starter plan ($79/mo)
STRIPE_PRICE_GROWTH=                   # Stripe Price ID for Growth plan ($129/mo)
STRIPE_PRICE_PRO=                      # Stripe Price ID for Pro plan ($199/mo)
STRIPE_PRICE_ENTERPRISE=               # Stripe Price ID for Enterprise plan ($399/mo)
STRIPE_PRICE_AGENCY=                   # Stripe Price ID for Agency plan ($999/mo)

# ── Crypto (Coinbase Commerce) ─────────────────────────────────────
COINBASE_WEBHOOK_SECRET=               # HMAC secret for charge webhook verification

# ── Cloudflare (DNS + custom domain automation) ────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=                  # needs DNS:Edit permission on the MINE zone

# ── Google services ────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=                 # for prospector.js lead-finding

# ── Push notifications (web + mobile) ──────────────────────────────
VAPID_EMAIL=                           # contact email for web-push
VAPID_PUBLIC_KEY=                      # generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
FCM_SERVER_KEY=                        # Firebase Cloud Messaging (mobile push)

# ── Storage ────────────────────────────────────────────────────────
S3_BUCKET=                             # alt spelling — most routes use AWS_S3_BUCKET
UPLOAD_DIR=./uploads                   # local-disk fallback when S3 not configured
MAX_FILE_SIZE_MB=50                    # per-file upload cap

# ── Platform economics ─────────────────────────────────────────────
PLATFORM_FEE_PERCENT=2.5                # take rate on crypto + agency revenue-share
AFFILIATE_MIN_PAYOUT=50                 # minimum payout threshold for affiliates ($USD)


