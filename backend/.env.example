# MINE — environment variable reference (.env.example)
# Copy to .env and fill in real values. NEVER commit a file containing real secrets.
# Blank entries are secrets/credentials/IDs you must supply per environment.
# Commented entries are optional overrides with safe code defaults — uncomment only to change them.
# (Corrected 2026-06-18: activated functional keys that were commented out, removed a stray line,
#  de-duplicated, and grouped into sections. No previously-set example values were changed.)

# ─────────────────────────────────────────────────────────────────────────────
# 1. CORE RUNTIME — required to boot
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=
BACKEND_URL=
DATABASE_URL=                          # Postgres in prod; leave blank to use local SQLite
DB_PATH=/app/data                      # SQLite location (dev / single-box)

# ── Secrets (generate long random strings) ──
JWT_SECRET=
JWT_REFRESH_SECRET=
OAUTH_STATE_SECRET=
INTERNAL_API_KEY=
CRON_SECRET=                           # also auth for the Agent Loop tick (/api/agent-loop)
CREDENTIAL_VAULT_KEY=                   # REQUIRED — encrypts users' BYOK keys (EasyPost, social, browser agent)
CREDENTIAL_VAULT_SECRET=               # REQUIRED — vault salt

# ── Admin / host identity ──
ADMIN_API_KEY=
ADMIN_EMAIL=
SUPPORT_EMAIL=
API_BASE_URL=
API_HOST=
APP_URL=
SERVER_URL=
MAIN_HOST=
MINE_DOMAIN=
# ADMIN_KEY=                           # alias for ADMIN_API_KEY
# DASHBOARD_URL=                       # alias for FRONTEND_URL
# LOG_LEVEL=info
LOG_SAFE_JSON=

# ─────────────────────────────────────────────────────────────────────────────
# 2. ANTHROPIC / CLAUDE — every AI feature
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                     # also powers Smart Notes parsing + ask-your-notes (/api/notes)
CLAUDE_API_KEY=                        # set to the same value (alias used by a few modules)
ANTHROPIC_MODEL=claude-sonnet-4-6      # default workhorse; set claude-opus-4-8 only for flagship-quality flows
ANTHROPIC_MODEL_CONTENT=
OPENAI_API_KEY=                        # LLM fallback
GEMINI_API_KEY=                        # image + LLM fallback
XAI_API_KEY=                           # xAI Grok TTS — premium AI-receptionist voices (falls back to Twilio Polly if unset)
PERPLEXITY_API_KEY=                    # research / web answers

# ─────────────────────────────────────────────────────────────────────────────
# 3. STRIPE — billing, checkout, payouts
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PRICE_IDS_PATH=./config/stripe-prices.live.json
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_AGENCY=
STRIPE_SEO_AGENT_PRICE_ID=             # per-agent add-on
STRIPE_BROWSER_AGENT_PRICE_ID=         # per-agent add-on
USE_STRIPE_TAX=
PLATFORM_FEE_PERCENT=2.5               # take rate on crypto + agency revenue-share
AFFILIATE_MIN_PAYOUT=50                # minimum payout threshold for affiliates ($USD)
DEFAULT_HOURLY_RATE=
DEFAULT_SIGNUP_PROMO=LAUNCH50          # auto-applied at checkout when user enters none. Set to "none" to disable.

# ─────────────────────────────────────────────────────────────────────────────
# 4. EMAIL — SendGrid (+ SMTP fallback)
# ─────────────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
EMAIL_FROM=                            # set these three to the same address
FROM_EMAIL=
SENDGRID_FROM_NAME=
EMAIL_FROM_DOMAIN=                     # for inbound reply branching (MX → SendGrid Inbound Parse)
SENDGRID_WEBHOOK_PUBLIC_KEY=
SENDGRID_WEBHOOK_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────────────────────────────────────
# 5. TWILIO — SMS / WhatsApp / voice
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_FROM=
TWILIO_PROSPECTOR_NUMBER=
SMS_SENDER_NAME=                       # alpha-sender name for regions that support it

# ── WhatsApp Business (Meta Cloud API) ──
WHATSAPP_APP_SECRET=
WHATSAPP_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_NUMBER=
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# 6. COMMERCE & OPS — shipping, Shopify, domains, storage, crypto
# ─────────────────────────────────────────────────────────────────────────────
EASYPOST_API_KEY=                      # multi-courier shipping (platform fallback; users also BYOK in-app)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_STORE_DOMAIN=
# SHOPIFY_REDIRECT_URI=
# SHOPIFY_SCOPES=
# SHOPIFY_SYNC_POLL_MIN=   SHOPIFY_RECOVERY_POLL_MIN=   SHOPIFY_RECOVERY_DELAY_MIN=
# SHOPIFY_BILLING_TEST=    SHOPIFY_TPL_ORDER=   SHOPIFY_TPL_SHIPPING=   SHOPIFY_TPL_RECOVERY=   SHOPIFY_TPL_LANG=

# ── Cloudflare — custom domains + SSL + site hosting ──
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── Storage (S3) — falls back to local disk if unset ──
AWS_S3_BUCKET=
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CLOUDFRONT_URL=
UPLOAD_DIR=./uploads                   # local-disk fallback when S3 not configured
MAX_FILE_SIZE_MB=50                    # per-file upload cap

# ── Crypto payments (Coinbase Commerce) ──
COINBASE_COMMERCE_API_KEY=
COINBASE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# 7. AI MEDIA — video & image generation
# ─────────────────────────────────────────────────────────────────────────────
# Video priority chain: Kling (primary) → Higgsfield DoP / Runway (fallbacks); HeyGen for avatars.
KLING_API_KEY=                         # PRIMARY cinematic video (Kling via PiAPI)
# KLING_API_BASE=   KLING_MODEL=   KLING_T2V_PATH=   KLING_I2V_PATH=   KLING_STATUS_PATH=   # overrides (have defaults)
# Higgsfield — premium AI images (Soul) + cinematic image-to-video (DoP). NOTE: HF_*, not HIGGSFIELD_*.
# Used FIRST in the image pipeline when quality=premium or a Soul ID is set (character-consistent imagery).
HF_API_KEY=
HF_API_SECRET=
# HF_CREDENTIALS=key:secret            # combined alternative to the two lines above
# HF_KEY=                              # legacy alias for HF_API_KEY
# HF_API_BASE=https://platform.higgsfield.ai   # override only if Higgsfield changes their API base
RUNWAY_API_KEY=                        # text→video fallback
HEYGEN_API_KEY=                        # avatar / talking-head video
HEYGEN_WEBHOOK_SECRET=
# HEYGEN_AVATAR_ID=
REPLICATE_API_KEY=
NANOBANANA_API_KEY=                    # Gemini image generation
GOOGLE_PLACES_API_KEY=                 # place/business lookups
SERPAPI_KEY=                           # SEO Agent rank tracking / SERP scraping

# ─────────────────────────────────────────────────────────────────────────────
# 8. OAUTH — social, ads & sign-in (enable only the providers you use)
# ─────────────────────────────────────────────────────────────────────────────
# Google (sign-in, Calendar, Ads)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_ACCESS_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
# Meta / Facebook / Instagram
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# TikTok (organic + ads)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
# X / Twitter (organic + ads)
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_REDIRECT_URI=
X_ADS_ACCESS_TOKEN=
X_ADS_ACCOUNT_ID=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=
LINKEDIN_ORG_ID=
# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_ACCESS_TOKEN=
# REDDIT_REDIRECT_URI=
# Apple (sign-in)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_SERVICE_ID=
# Microsoft 365 (mail/calendar via Graph)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common
# MS_TENANT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# 9. ACCOUNTING — Xero & QuickBooks
# ─────────────────────────────────────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_ACCESS_TOKEN=
XERO_TENANT_ID=
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ENV=production               # or "sandbox"
QBO_ACCESS_TOKEN=
QBO_REALM_ID=

# ─────────────────────────────────────────────────────────────────────────────
# 10. PUSH NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────────────
VAPID_EMAIL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
FCM_SERVER_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# 11. BROWSER AGENT (Web Hands) — uses CREDENTIAL_VAULT_KEY for stored logins
# ─────────────────────────────────────────────────────────────────────────────
BROWSER_AGENT_RUNNER_URL=
# BROWSER_AGENT_MAX_ACTIONS=40
# BROWSER_AGENT_FORBIDDEN_PATTERNS=
# BROWSER_AGENT_SYSTEM_PROMPT=

# ─────────────────────────────────────────────────────────────────────────────
# 12. ANALYTICS, OPS & MISC
# ─────────────────────────────────────────────────────────────────────────────
GA_API_SECRET=
GA_MEASUREMENT_ID=
CALENDLY_API_KEY=
PROPOSAL_SIGNING_KEY=                  # signs proposal/e-signature links
LEAD_NOTIFICATION_EMAIL=              # where new-lead alerts go
VEIL_SWAP_URL=

# ─────────────────────────────────────────────────────────────────────────────
# 13. FEATURE FLAGS & TUNING (safe defaults)
# ─────────────────────────────────────────────────────────────────────────────
OUTREACH_EMAIL_RATE=
OUTREACH_SMS_RATE=
OUTREACH_WHATSAPP_RATE=
TAILWIND_BACKFILL=
TAILWIND_BACKFILL_MAX=
# DESIGN_DAILY_COST_CAP=               # daily spend cap for the AI Designer

# -----------------------------------------------------------------------------
# 14. Optional webhook integrations (read via getSetting; safe to leave unset)
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=            # if set, hosting.js posts notifications to this Slack webhook
# ZAPIER_WEBHOOK_URL=           # if set, hosting.js / integrations trigger this Zapier hook

# ─────────────────────────────────────────────────────────────────────────────
# Genuinely-missing vars (added during wiring audit). NOTE: ADMIN_KEY,
# DASHBOARD_URL, LOG_LEVEL, BROWSER_AGENT_*, MS_TENANT_ID, HEYGEN_AVATAR_ID,
# KLING_API_BASE and HF_* are ALREADY documented as commented optionals above —
# don't re-add them here.
# ─────────────────────────────────────────────────────────────────────────────
PUBLIC_URL=                      # public base URL of the app (links/callbacks)
CONTACT_TO=support@mine.app      # inbox for contact-form submissions (routes/contact.js)
# Kling video sub-paths — have code defaults; set only to override
KLING_MODEL=
KLING_T2V_PATH=
KLING_I2V_PATH=
KLING_STATUS_PATH=

# ── Google Sign-In (Continue with Google) ──
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET are defined above (shared with other Google OAuth).
# In Google Cloud → Credentials → your OAuth client, add this Authorized redirect URI:
#   {BACKEND_URL}/api/auth/google/callback
GOOGLE_REDIRECT_ALLOWLIST=        # optional: extra domains the OAuth flow may redirect back to (comma-sep), e.g. mine.app,app.mine.app
