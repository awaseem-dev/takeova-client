# ════════════════════════════════════════════════════════════════════════════
#  MINE — backend environment variables
# ════════════════════════════════════════════════════════════════════════════
#  Fill in every value marked REQUIRED before starting the backend.
#  OPTIONAL ones can be left blank or omitted — the feature will just be
#  disabled gracefully.
#
#  How it's used:  backend/server.js + routes/*.js read these via process.env.
#  Validate on boot: run `node preflight.js` before `npm start`.
# ════════════════════════════════════════════════════════════════════════════

# ── CORE ──────────────────────────────────────────────────────────────────
ADMIN_EMAIL=     # REQUIRED  (used in 3 files)
API_HOST=     # optional  (used in 1 file)
